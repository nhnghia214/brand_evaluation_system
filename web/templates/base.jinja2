<!DOCTYPE html>
<html lang="vi" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}AI Brand Evaluator{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        space: { 900: '#0B0F19', 800: '#111827', 700: '#1F2937' },
                        brand: { neon: '#8B5CF6', light: '#C4B5FD' }
                    }
                }
            }
        }
    </script>
    <style>
        html {
            scroll-behavior: smooth;
        }
    </style>
</head>
<body class="bg-space-900 text-white font-sans antialiased selection:bg-brand-neon selection:text-white flex flex-col min-h-screen">

    {% block header %}
    <header class="border-b border-space-700/50 backdrop-blur-md sticky top-0 w-full z-50 bg-space-900/80">
        <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between gap-4">
            
            <div class="flex-shrink-0">
                <a href="/" class="text-xl font-bold tracking-tighter flex items-center gap-2">
                    <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg text-sm">AI</span>
                    <span class="hidden sm:block">BrandAgent</span>
                </a>
            </div>
            
            <nav class="hidden lg:flex items-center gap-6 justify-center flex-1">
                <a href="/#features" class="text-sm font-medium text-gray-400 hover:text-brand-light transition whitespace-nowrap">Tính năng</a>
                <a href="/#how-it-works" class="text-sm font-medium text-gray-400 hover:text-brand-light transition whitespace-nowrap">Hướng dẫn</a>
                <a href="/#about-us" class="text-sm font-medium text-gray-400 hover:text-brand-light transition whitespace-nowrap">Về chúng tôi</a>
            </nav>

            <div class="flex items-center gap-2 md:gap-3 flex-shrink-0">
                
                <a href="/static/BrandAgent.apk" download class="hidden xl:flex items-center gap-1.5 text-xs font-bold text-brand-light hover:text-white transition group border border-brand-light/30 px-3 py-1.5 rounded-full whitespace-nowrap">
                    <svg class="w-4 h-4 group-hover:scale-110 transition" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M17.523 15.3414L20.355 20.2467C20.5516 20.5873 20.435 21.0205 20.0945 21.217C19.7539 21.4136 19.3207 21.297 19.1241 20.9565L16.2629 16H7.73712L4.87586 20.9565C4.67931 21.297 4.24612 21.4136 3.90554 21.217C3.56495 21.0205 3.44837 20.5873 3.64493 20.2467L6.47696 15.3414C3.1259 13.5684 1 10.0526 1 6H23C23 10.0526 20.8741 13.5684 17.523 15.3414ZM7.5 10C8.05228 10 8.5 9.55228 8.5 9C8.5 8.44772 8.05228 8 7.5 8C6.94772 8 6.5 8.44772 6.5 9C6.5 9.55228 6.94772 10 7.5 10ZM16.5 10C17.0523 10 17.5 9.55228 17.5 9C17.5 8.44772 17.0523 8 16.5 8C15.9477 8 15.5 8.44772 15.5 9C15.5 9.55228 15.9477 10 16.5 10Z"/>
                    </svg>
                    Tải APK
                </a>

                {% if user %}
                    <div class="flex items-center gap-2 bg-space-800 border border-space-700 px-2 lg:px-3 py-1.5 rounded-full hidden md:flex">
                        <span class="text-xs lg:text-sm font-medium text-brand-light border-r border-space-600 pr-2 truncate max-w-[80px] lg:max-w-[120px]">
                            Xin chào, {{ user.name }}
                        </span>
                        
                        <div class="flex items-center gap-1.5 border-r border-space-600 pr-2">
                            <span class="text-yellow-400 font-bold text-xs lg:text-sm whitespace-nowrap">{{ user.token }} tokens </span>
                            <a href="/checkout" class="bg-yellow-500/10 hover:bg-yellow-500/20 text-yellow-500 text-[10px] px-1.5 py-0.5 rounded border border-yellow-500/20 transition-all font-bold uppercase tracking-wider flex items-center whitespace-nowrap">
                                + Nạp
                            </a>
                        </div>

                        <span class="text-[10px] lg:text-xs font-bold px-1.5 py-0.5 rounded-md {% if user.tier == 'VIP' %}bg-brand-neon/20 text-brand-light{% else %}bg-gray-700 text-gray-300{% endif %} whitespace-nowrap">
                            {{ user.tier }}
                        </span>
                    </div>
                    
                    {% if user.role == 'admin' %}
                        <a href="/admin" class="text-xs lg:text-sm text-gray-400 hover:text-white transition px-2 hidden sm:block whitespace-nowrap">Admin</a>
                    {% else %}
                        <a href="/dashboard" class="text-xs lg:text-sm text-gray-400 hover:text-white transition px-2 hidden sm:block whitespace-nowrap">Dashboard</a>
                    {% endif %}
                    
                    <a href="/auth/logout" class="bg-red-500/10 hover:bg-red-500/20 text-red-400 px-4 py-1.5 rounded-full text-xs lg:text-sm font-medium transition border border-red-500/10 ml-1 whitespace-nowrap">
                        Logout
                    </a>
                {% else %}
                    <a href="/auth/login" class="bg-brand-neon hover:bg-purple-500 text-white text-sm font-bold py-2.5 px-6 rounded-full shadow-[0_0_15px_rgba(139,92,246,0.4)] transition transform hover:scale-105 whitespace-nowrap">
                        Bắt đầu ngay
                    </a>
                {% endif %}
            </div>
        </div>
    </header>
    {% endblock %}

    <main class="flex-1 flex flex-col">
        {% block content %}{% endblock %}
    </main>

    <footer class="bg-[#080B13] border-t border-space-800 py-10 px-6 mt-auto w-full relative z-20">
        <div class="max-w-7xl mx-auto flex flex-col items-center">
            <div class="flex items-center gap-4 mb-6">
                <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center font-bold text-[10px] text-white shadow-lg">AI</div>
                    <span class="font-bold text-brand-light text-base tracking-tight">BrandAgent</span>
                </div>
                <span class="text-space-700">|</span>
                <span class="text-gray-500 text-sm">© 2026 Công nghệ AI · <span class="text-red-500 font-bold text-xs">BETA</span></span>
            </div>

            <div class="flex flex-col items-center gap-4 text-sm text-gray-400 font-medium w-full">
                <div class="flex flex-wrap justify-center gap-x-8 gap-y-3">
                    <a href="/#features" class="hover:text-white transition">Tính năng</a>
                    <a href="/page/cau-chuyen" class="hover:text-white transition">Câu chuyện BrandAgent</a>
                    <a href="/page/lien-he" class="hover:text-white transition">Liên hệ hỗ trợ & Về đội ngũ</a>
                    <a href="/page/dieu-khoan" class="hover:text-white transition">Điều khoản dịch vụ & Chính sách bảo mật</a>
                </div>
                <div class="flex flex-wrap justify-center gap-x-8 gap-y-3">
                    <a href="/page/faq" class="hover:text-white transition">Câu hỏi thường gặp</a>
                    <a href="/checkout" class="hover:text-white transition text-brand-light">Bảng giá & Gói hội viên cao cấp</a>
                </div>
                {% if not user %}
                <div class="mt-2">
                    <a href="/auth/login" class="text-brand-neon hover:text-purple-400 font-bold transition">Đăng nhập</a>
                </div>
                {% endif %}
            </div>

            <div class="text-center text-xs text-gray-600 mt-10 italic border-t border-space-800/50 pt-6 w-full max-w-3xl">
                Hệ thống đang trong giai đoạn thử nghiệm (Beta). Mọi giao dịch phục vụ mục đích trải nghiệm công nghệ.
            </div>
        </div>
    </footer>

</body>
</html>
