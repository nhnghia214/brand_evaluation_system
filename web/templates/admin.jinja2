{% extends "base.jinja2" %}

{% block title %}Admin Panel - System{% endblock %}

{% block header %}{% endblock %}

{% block content %}
<div class="flex h-screen w-full bg-space-900 overflow-hidden text-white font-sans">
    
    <aside class="w-64 border-r border-space-700 bg-space-800/80 backdrop-blur-md flex flex-col z-20">
        <div class="h-16 flex items-center px-6 border-b border-space-700 font-bold tracking-tight">
            <span class="text-brand-neon mr-2 text-xl">Admin</span>Panel
        </div>
        
        <nav class="flex-1 p-4 space-y-2">
            <a href="/admin?tab=overview" class="block px-4 py-2.5 rounded-lg transition {% if tab == 'overview' %}bg-brand-neon/10 text-brand-light font-medium border border-brand-neon/20{% else %}text-gray-400 hover:bg-space-700 hover:text-white{% endif %}">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                    Thống kê chung
                </div>
            </a>
            
            <a href="/admin?tab=brands" class="block px-4 py-2.5 rounded-lg transition {% if tab == 'brands' %}bg-brand-neon/10 text-brand-light font-medium border border-brand-neon/20{% else %}text-gray-400 hover:bg-space-700 hover:text-white{% endif %}">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                    Quản lý Thương hiệu
                </div>
            </a>

            <a href="/admin?tab=jobs" class="block px-4 py-2.5 rounded-lg transition {% if tab == 'jobs' %}bg-brand-neon/10 text-brand-light font-medium border border-brand-neon/20{% else %}text-gray-400 hover:bg-space-700 hover:text-white{% endif %}">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    Quản lý Job Crawl
                </div>
            </a>
            
            <a href="/admin?tab=logs" class="block px-4 py-2.5 rounded-lg transition {% if tab == 'logs' %}bg-brand-neon/10 text-brand-light font-medium border border-brand-neon/20{% else %}text-gray-400 hover:bg-space-700 hover:text-white{% endif %}">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    Logs hệ thống
                </div>
            </a>
        
            <a href="/admin?tab=requests" class="block px-4 py-2.5 rounded-lg transition {% if tab == 'requests' %}bg-brand-neon/10 text-brand-light font-medium border border-brand-neon/20{% else %}text-gray-400 hover:bg-space-700 hover:text-white{% endif %}">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    Quản lý Yêu cầu
                </div>
            </a>
            
            <a href="/admin?tab=revenue" class="block px-4 py-2.5 rounded-lg transition {% if tab == 'revenue' %}bg-green-500/10 text-green-400 font-medium border border-green-500/20{% else %}text-gray-400 hover:bg-space-700 hover:text-white{% endif %}">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Thống kê Doanh thu
                </div>
            </a>
        </nav>
        
        <div class="p-4 border-t border-space-700 space-y-3">
            <a href="/" class="flex items-center gap-3 text-sm text-gray-400 hover:text-white transition px-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                Trở về Landing
            </a>
        </div>
    </aside>

    <div class="flex-1 flex flex-col overflow-hidden relative">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-500/5 rounded-full blur-[100px] pointer-events-none"></div>

        <header class="h-16 border-b border-space-700 flex items-center justify-between px-8 bg-space-900/50 backdrop-blur-sm z-10">
            <h1 class="text-lg font-semibold capitalize">
                {% if tab == 'overview' %}Dashboard Overview
                {% elif tab == 'brands' %}Quản lý Thương hiệu
                {% elif tab == 'jobs' %}Quản lý tiến trình (Crawl Jobs)
                {% elif tab == 'logs' %}System Logs (Deep Crawl)
                {% elif tab == 'requests' %}Quản lý Yêu cầu
                {% elif tab == 'revenue' %}Thống kê & Báo cáo Tài chính
                {% endif %}
            </h1>
            <div class="flex items-center gap-4">
                <a href="/admin?tab=requests" class="relative p-2 text-gray-400 hover:text-white transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                    {% if pending_appeals and pending_appeals > 0 %}
                    <span class="absolute top-1 right-1 flex h-3 w-3">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500 border border-space-900"></span>
                    </span>
                    {% endif %}
                </a>

                <div class="text-right hidden sm:block">
                    <p class="text-sm font-medium">{{ user.name if user else 'Administrator' }}</p>
                    <p class="text-xs text-brand-neon">System Active</p>
                </div>
                <div class="w-9 h-9 rounded-full bg-gradient-to-tr from-purple-500 to-indigo-500 flex items-center justify-center font-bold shadow-lg">
                    {{ user.name[0]|upper if user else 'A' }}
                </div>
                <div class="h-6 w-px bg-space-700 mx-1"></div>
                <a href="/auth/logout" class="flex items-center gap-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 px-3 py-1.5 rounded-lg transition" title="Đăng xuất">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                    <span class="text-sm font-medium hidden md:block">Thoát</span>
                </a>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto p-8 z-10">
            
            {% if tab == 'overview' %}
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <a href="/admin?tab=brands" class="block bg-space-800 border border-space-700 rounded-xl p-6 shadow-lg hover:border-brand-neon hover:shadow-brand-neon/10 transition group cursor-pointer">
                    <p class="text-gray-400 text-sm mb-1 uppercase tracking-wider font-semibold group-hover:text-brand-light transition flex justify-between items-center">
                        Tổng Thương Hiệu 
                        <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </p>
                    <h3 class="text-3xl font-bold text-white">{{ total_brands }}</h3>
                </a>

                <div class="bg-space-800 border border-space-700 rounded-xl p-6 shadow-lg">
                    <p class="text-gray-400 text-sm mb-1 uppercase tracking-wider font-semibold">Job Đang Hoạt Động</p>
                    <h3 class="text-3xl font-bold text-brand-light">{{ active_jobs }}</h3>
                </div>
                <div class="bg-space-800 border border-space-700 rounded-xl p-6 shadow-lg">
                    <p class="text-gray-400 text-sm mb-1 uppercase tracking-wider font-semibold">Tổng Reviews (Data)</p>
                    <h3 class="text-3xl font-bold text-white">{{ total_reviews }}</h3>
                </div>
            </div>

            <div class="bg-space-800 border border-space-700 rounded-xl p-6 mb-8 shadow-lg">
                <h2 class="font-semibold text-lg mb-4 text-gray-200">Tốc độ thu thập dữ liệu (7 ngày qua)</h2>
                <div class="h-64 w-full">
                    <canvas id="growthChart"></canvas>
                </div>
            </div>

            <div class="bg-space-800 border border-space-700 rounded-xl overflow-hidden shadow-lg">
                <div class="px-6 py-4 border-b border-space-700 flex justify-between items-center">
                    <h2 class="font-semibold text-lg">Tiến trình Crawl hệ thống gần đây</h2>
                </div>
                <table class="w-full text-left text-sm">
                    <thead class="bg-space-900/50 text-gray-400">
                        <tr>
                            <th class="px-6 py-4 font-medium">Mã Job</th>
                            <th class="px-6 py-4 font-medium">Thương hiệu</th>
                            <th class="px-6 py-4 font-medium">Danh mục</th>
                            <th class="px-6 py-4 font-medium">Thời gian tạo</th>
                            <th class="px-6 py-4 font-medium">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-space-700">
                        {% for job in recent_jobs %}
                        <tr class="hover:bg-space-700/30 transition">
                            <td class="px-6 py-4 text-gray-400">#{{ job.job_id }}</td>
                            <td class="px-6 py-4 font-medium text-white">{{ job.brand }}</td>
                            <td class="px-6 py-4 text-gray-400">{{ job.category }}</td>
                            <td class="px-6 py-4 text-gray-400">{{ job.time }}</td>
                            <td class="px-6 py-4">
                                {% if job.status == 'COMPLETED' %}
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">Hoàn tất</span>
                                {% elif job.status == 'RUNNING' or job.status == 'COLLECTING' %}
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20"><span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>Đang chạy</span>
                                {% elif job.status == 'FAILED' %}
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-red-500/10 text-red-400 border border-red-500/20">Lỗi</span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-gray-500/10 text-gray-400 border border-gray-500/20">{{ job.status }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">Chưa có dữ liệu tiến trình nào.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% elif tab == 'brands' %}
            <div class="bg-space-800 border border-space-700 rounded-xl overflow-hidden shadow-lg">
                <div class="px-6 py-4 border-b border-space-700 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <h2 class="font-semibold text-lg">Danh sách Thương hiệu</h2>
                    
                    <div class="flex items-center gap-3 w-full sm:w-auto">
                        <select class="bg-space-900 border border-space-600 rounded-lg px-4 py-2.5 text-sm text-gray-300 focus:outline-none focus:border-brand-neon transition w-full sm:w-48">
                            <option value="">Tất cả danh mục...</option>
                            {% for cat in categories %}
                                <option value="{{ cat.CategoryId }}">{{ cat.CategoryName }}</option>
                            {% endfor %}
                        </select>

                        <button class="bg-brand-neon hover:bg-purple-500 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition flex items-center gap-2 whitespace-nowrap">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                            Thêm mới
                        </button>
                    </div>
                </div>

                <table class="w-full text-left text-sm">
                    <thead class="bg-space-900/50 text-gray-400">
                        <tr>
                            <th class="px-6 py-4 font-medium w-24">ID</th>
                            <th class="px-6 py-4 font-medium">Tên Thương hiệu</th>
                            <th class="px-6 py-4 font-medium">Ngày tạo vào DB</th>
                            <th class="px-6 py-4 font-medium text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-space-700">
                        {% for brand in all_brands %}
                        <tr class="hover:bg-space-700/30 transition group">
                            <td class="px-6 py-4 text-gray-400">#{{ brand.BrandId }}</td>
                            <td class="px-6 py-4 font-bold text-white text-base">{{ brand.BrandName }}</td>
                            <td class="px-6 py-4 text-gray-400">{{ brand.CreatedAt.strftime('%d/%m/%Y %H:%M') if brand.CreatedAt else 'N/A' }}</td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
                                    <button class="p-1.5 bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 rounded-md transition" title="Chỉnh sửa">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    </button>
                                    <button class="p-1.5 bg-red-500/10 hover:bg-red-500/20 text-red-500 rounded-md transition" title="Xóa" onclick="confirm('Bạn có chắc muốn xóa thương hiệu này khỏi CSDL? Toàn bộ dữ liệu cào sẽ bị ảnh hưởng.')">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="4" class="px-6 py-8 text-center text-gray-500">Chưa có thương hiệu nào.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% elif tab == 'jobs' %}
            <div class="bg-space-800 border border-space-700 rounded-xl overflow-hidden shadow-lg">
                
                <div class="px-6 py-4 border-b border-space-700 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <h2 class="font-semibold text-lg">Quản lý & Điều phối Job Crawl</h2>
                    <div class="relative w-full sm:w-64">
                        <input type="text" placeholder="Tìm theo thương hiệu..." class="w-full bg-space-900 border border-space-600 rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:border-brand-neon transition pl-10">
                        <svg class="w-4 h-4 text-gray-400 absolute left-3 top-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    </div>
                </div>

                <table class="w-full text-left text-sm">
                    <thead class="bg-space-900/50 text-gray-400">
                        <tr>
                            <th class="px-6 py-4 font-medium">Mã Job</th>
                            <th class="px-6 py-4 font-medium">Thương hiệu</th>
                            <th class="px-6 py-4 font-medium">Thời gian tạo</th>
                            <th class="px-6 py-4 font-medium">Trạng thái</th>
                            <th class="px-6 py-4 font-medium text-right">Điều khiển</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-space-700">
                        {% for job in all_jobs %}
                        <tr class="hover:bg-space-700/30 transition group">
                            <td class="px-6 py-4 text-gray-400">#{{ job.JobId }}</td>
                            <td class="px-6 py-4 font-medium text-white">{{ job.BrandName or 'N/A' }} <span class="block text-xs text-gray-500 font-normal">{{ job.CategoryName or 'N/A' }}</span></td>
                            <td class="px-6 py-4 text-gray-400">{{ job.CreatedAt.strftime('%d/%m %H:%M') if job.CreatedAt else 'N/A' }}</td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 rounded-full text-xs font-medium 
                                    {% if job.JobStatus == 'COMPLETED' %}bg-green-500/10 text-green-400
                                    {% elif job.JobStatus in ['RUNNING', 'COLLECTING'] %}bg-blue-500/10 text-blue-400 animate-pulse
                                    {% elif job.JobStatus == 'PAUSED' %}bg-yellow-500/10 text-yellow-400
                                    {% elif job.JobStatus == 'FAILED' %}bg-red-500/10 text-red-400
                                    {% else %}bg-gray-500/10 text-gray-400{% endif %}">
                                    {{ job.JobStatus }}
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-2 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
                                    
                                    {% if job.JobStatus == 'RUNNING' or job.JobStatus == 'PENDING' or job.JobStatus == 'COLLECTING' %}
                                        <form method="POST" action="/admin/job/{{ job.JobId }}/action" style="display:inline;">
                                            <input type="hidden" name="action" value="pause">
                                            <button type="submit" class="px-3 py-1 rounded-md bg-yellow-500/20 text-yellow-400 hover:bg-yellow-500/30 transition text-xs font-medium border border-yellow-500/20">⏸ Tạm dừng</button>
                                        </form>

                                    {% elif job.JobStatus == 'PAUSED' %}
                                        <form method="POST" action="/admin/job/{{ job.JobId }}/action" style="display:inline;">
                                            <input type="hidden" name="action" value="resume">
                                            <button type="submit" class="px-3 py-1 rounded-md bg-green-500/20 text-green-400 hover:bg-green-500/30 transition text-xs font-medium border border-green-500/20">▶️ Tiếp tục</button>
                                        </form>
                                    {% endif %}

                                    {% if job.JobStatus not in ['COMPLETED', 'FAILED'] %}
                                        <form method="POST" action="/admin/job/{{ job.JobId }}/action" class="inline" onsubmit="return confirm('Bạn có chắc muốn hủy Job này? Tiến trình Crawler sẽ bị buộc dừng.');">
                                            <input type="hidden" name="action" value="cancel">
                                            <button type="submit" class="p-1.5 bg-red-500/10 hover:bg-red-500/20 text-red-500 rounded-md transition border border-red-500/10" title="Hủy bỏ">
                                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg>
                                            </button>
                                        </form>
                                    {% endif %}

                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">Chưa có job nào trên hệ thống.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% elif tab == 'logs' %}
