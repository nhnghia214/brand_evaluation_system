<script>
    // Hàm mở Modal chuẩn (xóa hidden, thêm flex)
    function openAdminModal(modalId) {
        const modal = document.getElementById(modalId);
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }

    // Hàm đóng Modal chuẩn (thêm hidden, xóa flex)
    function closeAdminModal(modalId) {
        const modal = document.getElementById(modalId);
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }

    // Hàm mở chi tiết người dùng
    function openDetailModal(name, email, phone, address, brands) {
        document.getElementById('mdName').innerText = name;
        document.getElementById('mdEmail').innerText = email;
        document.getElementById('mdPhone').innerText = phone || 'Không có';
        document.getElementById('mdAddress').innerText = address || 'Không có';
        document.getElementById('mdBrands').innerText = brands;
        openAdminModal('detailModal');
    }
</script>

