{% if tab == 'revenue' %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Định dạng Chart.js cho Dark Mode
    Chart.defaults.color = '#9CA3AF';
    Chart.defaults.borderColor = 'rgba(55, 65, 81, 0.4)';

    // 1. Biểu đồ Đường (Doanh thu)
    const revLabels = {{ rev_labels | default([]) | tojson }};
    const revData = {{ rev_data | default([]) | tojson }};
    new Chart(document.getElementById('revenueChart'), {
        type: 'line',
        data: {
            labels: revLabels,
            datasets: [{
                label: 'Doanh thu (VNĐ)',
                data: revData,
                borderColor: '#10B981', // Emerald 500
                backgroundColor: 'rgba(16, 185, 129, 0.1)',
                borderWidth: 3,
                tension: 0.3,
                fill: true,
                pointBackgroundColor: '#34D399',
                pointRadius: 4
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true } }
        }
    });

    // 2. Biểu đồ Tròn (Tỷ lệ Gói dịch vụ)
    const packageStats = {{ package_stats | default([]) | tojson | safe }};
    const pieLabels = packageStats.map(item => item.Goi_DichVu);
    let pieData = packageStats.map(item => item.Qty);
    
    // Xử lý chống tàng hình: Tính tổng số đơn. Nếu = 0 thì cho hiển thị vòng xám
    const totalSum = pieData.reduce((a, b) => a + b, 0);
    let bgColors = ['#8B5CF6', '#3B82F6', '#10B981', '#F59E0B', '#EF4444', '#6B7280'];
    
    if (totalSum === 0) {
        pieData = [1]; // Tạo 1 data ảo để vẽ vòng tròn 100%
        bgColors = ['#374151']; // Màu xám tối
    }
    
    new Chart(document.getElementById('packageChart'), {
        type: 'doughnut',
        data: {
            labels: totalSum === 0 ? ['Chưa có đơn hàng nào'] : pieLabels,
            datasets: [{
                data: pieData,
                backgroundColor: bgColors,
                borderWidth: 0
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { color: '#D1D5DB', padding: 15 } },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            if (totalSum === 0) return ' 0 đơn';
                            return ' ' + context.formattedValue + ' đơn';
                        }
                    }
                }
            },
            cutout: '65%'
        }
    });

    // 3. Hàm xuất file Excel (CSV) bằng JavaScript thuần
    function exportToCSV() {
        let csv = [];
        let rows = document.querySelectorAll("#transactionTable tr");
        
        for (let i = 0; i < rows.length; i++) {
            let row = [], cols = rows[i].querySelectorAll("td, th");
            for (let j = 0; j < cols.length; j++) {
                // Xóa dấu phẩy trong số tiền để tránh lỗi CSV
                let data = cols[j].innerText.replace(/,/g, '').replace(/\n/g, ' '); 
                row.push('"' + data + '"');
            }
            csv.push(row.join(","));
        }

        // Tạo file và tự động tải xuống
        let csvFile = new Blob(["\uFEFF" + csv.join("\n")], {type: "text/csv;charset=utf-8;"});
        let downloadLink = document.createElement("a");
        downloadLink.download = "BaoCaoDoanhThu_BrandAgent.csv";
        downloadLink.href = window.URL.createObjectURL(csvFile);
        downloadLink.style.display = "none";
        document.body.appendChild(downloadLink);
        downloadLink.click();
    }
</script>
{% endif %}

{% endblock %}