<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>AI Đánh giá thương hiệu</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        body {
            background: #0f172a;
            color: #e5e7eb;
            font-family: Arial, sans-serif;
        }
        .container {
            width: 900px;
            margin: 50px auto;
        }
        textarea {
            width: 100%;
            height: 80px;
            padding: 10px;
            font-size: 16px;
        }
        button {
            margin-top: 10px;
            padding: 10px 20px;
            background: #2563eb;
            color: white;
            border: none;
            cursor: pointer;
        }
        .box {
            margin-top: 30px;
            padding: 20px;
            background: #020617;
            border-radius: 6px;
        }
        h1, h3 {
            margin-bottom: 10px;
        }
    </style>
</head>

<body>
<div class="container">
    <h1>🤖 AI Đánh giá thương hiệu</h1>

    <form method="post" action="/ask">
        <textarea name="question" placeholder="Nhập câu hỏi...">{{ question }}</textarea>
        <br>
        <button type="submit">Phân tích</button>
    </form>

    {% if chart_data %}
    <div class="box">
        <h3>📊 So sánh tổng hợp</h3>
        <canvas id="compareChart"></canvas>
    </div>
    {% endif %}

    {% if answer %}
    <div class="box">
        <h3>🧠 Kết luận & tư vấn</h3>
        <p style="white-space: pre-line;">{{ answer }}</p>
    </div>
    {% endif %}

    {% if debug_intent %}
    <div class="box">
        <h3>🧩 Intent Parser Output</h3>
        <pre style="color:#93c5fd;">{{ debug_intent }}</pre>
    </div>
    {% endif %}
</div>

{% if chart_data %}
<script>
const labels = {{ chart_data.labels | tojson }};
const scores = {{ chart_data.scores | tojson }};
const totalReviews = {{ chart_data.total_reviews | tojson }};

new Chart(document.getElementById('compareChart'), {
    type: 'bar',
    data: {
        labels: labels,
        datasets: [
            {
                label: 'Score',
                data: scores
            },
            {
                label: 'Total Reviews',
                data: totalReviews
            }
        ]
    },
    options: {
        responsive: true,
        scales: {
            y: { beginAtZero: true }
        }
    }
});
</script>
{% endif %}
</body>
</html>
