{% extends "base.jinja2" %}

{% block title %}Workspace - AI Brand Evaluator{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto w-full px-6 py-12 relative z-10">
    
    <div class="mb-8 text-center">
        <h1 class="text-3xl font-extrabold tracking-tight mb-2">Không gian Phân tích</h1>
        <p class="text-gray-400">Gửi yêu cầu đánh giá hoặc so sánh các thương hiệu (VD: Colorkey, Flower Knows, Asus,...)</p>
    </div>

    <div class="bg-space-800 border border-space-700 rounded-2xl p-6 mb-10 shadow-xl relative overflow-hidden group">
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-neon/20 rounded-full blur-[60px] group-hover:bg-brand-neon/30 transition duration-700"></div>
        
        <form method="post" action="/ask" class="relative z-10">
            <textarea name="question" rows="3" placeholder="Nhập câu hỏi... (Ví dụ: So sánh Vinamilk và TH True Milk)" 
                      class="w-full bg-space-900/50 border border-space-700 rounded-xl px-5 py-4 text-white placeholder-gray-500 focus:outline-none focus:border-brand-neon focus:ring-1 focus:ring-brand-neon transition resize-none mb-4">{{ question }}</textarea>
            <div class="flex justify-end">
                <button type="submit" class="bg-white text-gray-900 hover:bg-gray-200 px-6 py-2.5 rounded-lg font-semibold transition flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    Xử lý AI
                </button>
            </div>
        </form>
    </div>

    <div class="space-y-6">
        
        {% if answer %}
        <div class="bg-space-800 border border-space-700 rounded-2xl p-6 shadow-lg border-l-4 border-l-brand-neon">
            <h3 class="text-lg font-bold flex items-center gap-2 mb-3 text-white">
                <span>✨</span> Phân tích & Đánh giá
            </h3>
            <div class="text-gray-300 leading-relaxed whitespace-pre-line text-sm">
                {{ answer }}
            </div>
        </div>
        {% endif %}

        {% if chart_data %}
        <div class="bg-space-800 border border-space-700 rounded-2xl p-6 shadow-lg">
            <h3 class="text-lg font-bold flex items-center gap-2 mb-4 text-white">
                <span class="text-blue-400">📊</span> Tương quan dữ liệu
            </h3>
            <div class="bg-space-900 rounded-xl p-4 border border-space-700/50">
                <canvas id="compareChart" height="100"></canvas>
            </div>
        </div>
        {% endif %}

        {% if debug_intent %}
        <div class="bg-space-800 border border-space-700 rounded-2xl p-6 shadow-lg opacity-70 hover:opacity-100 transition">
            <h3 class="text-sm font-bold flex items-center gap-2 mb-3 text-gray-400 uppercase tracking-wider">
                ⚙️ Debug Intent Parser
            </h3>
            <pre class="text-brand-light text-xs bg-space-900 p-4 rounded-xl overflow-x-auto border border-space-700/50 font-mono">{{ debug_intent }}</pre>
        </div>
        {% endif %}

    </div>
</div>

{% if chart_data %}
<script>
    Chart.defaults.color = '#9CA3AF';
    Chart.defaults.borderColor = 'rgba(55, 65, 81, 0.5)';
    Chart.defaults.font.family = 'ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial';

    const labels = {{ chart_data.labels | tojson }};
    const scores = {{ chart_data.scores | tojson }};
    const totalReviews = {{ chart_data.total_reviews | tojson }};

    new Chart(document.getElementById('compareChart'), {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [
                {
                    label: 'Điểm số AI (Score)',
                    data: scores,
                    backgroundColor: '#8B5CF6',
                    borderRadius: 4,
                    yAxisID: 'y' // Gắn vào trục bên trái
                },
                {
                    label: 'Lượng Reviews',
                    data: totalReviews,
                    backgroundColor: '#3B82F6',
                    borderRadius: 4,
                    yAxisID: 'y1' // Gắn vào trục bên phải
                }
            ]
        },
        options: {
            responsive: true,
            interaction: {
                mode: 'index',
                intersect: false,
            },
            scales: {
                y: {
                    type: 'linear',
                    display: true,
                    position: 'left',
                    beginAtZero: true,
                    suggestedMax: 10, // Giả sử thang điểm AI của bạn là hệ số 10
                    title: {
                        display: true,
                        text: 'Điểm số AI',
                        color: '#8B5CF6'
                    }
                },
                y1: {
                    type: 'linear',
                    display: true,
                    position: 'right',
                    beginAtZero: true,
                    title: {
                        display: true,
                        text: 'Tổng lượng Review',
                        color: '#3B82F6'
                    },
                    // Tắt lưới (grid) của trục này để không bị đè vạch kẻ lên trục Y trái
                    grid: {
                        drawOnChartArea: false, 
                    },
                }
            },
            plugins: { 
                legend: { position: 'top' },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            let label = context.dataset.label || '';
                            if (label) { label += ': '; }
                            if (context.parsed.y !== null) {
                                label += context.parsed.y;
                            }
                            return label;
                        }
                    }
                }
            }
        }
    });
</script>
{% endif %}
{% endblock %}