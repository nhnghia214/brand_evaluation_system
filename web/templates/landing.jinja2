{% extends "base.jinja2" %}
{% block title %}BrandAgent - Đánh giá uy tín thương hiệu bằng AI{% endblock %}

{% block content %}
<style>
    /* Trạng thái ban đầu (Ẩn và lệch vị trí) */
    .reveal-left { opacity: 0; transform: translateX(-80px); transition: all 0.8s cubic-bezier(0.5, 0, 0, 1); }
    .reveal-right { opacity: 0; transform: translateX(80px); transition: all 0.8s cubic-bezier(0.5, 0, 0, 1); }
    .reveal-up { opacity: 0; transform: translateY(60px); transition: all 0.8s cubic-bezier(0.5, 0, 0, 1); }
    
    /* Trạng thái khi cuộn tới (Hiện và về đúng vị trí) */
    .reveal-active { opacity: 1; transform: translate(0, 0); }
</style>

<div class="relative overflow-hidden pt-20 pb-32 lg:pt-32 lg:pb-40 text-center">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-neon/20 rounded-full blur-[120px] pointer-events-none"></div>
    
    <div class="relative z-10 max-w-5xl mx-auto px-6 reveal-up">
        <div class="flex items-center justify-center gap-3 mb-8">
