<script>
    document.addEventListener("DOMContentLoaded", function() {
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.15 // Kích hoạt khi cuộn thấy 15% của khối
        };

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    // Thêm class 'reveal-active' để thực hiện CSS Transition
                    entry.target.classList.add('reveal-active');
                    // Gỡ theo dõi để hiệu ứng chỉ chạy 1 lần duy nhất
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        // Tìm tất cả các phần tử có gắn class reveal và bắt đầu theo dõi
        document.querySelectorAll('.reveal-left, .reveal-right, .reveal-up').forEach((el) => {
            observer.observe(el);
        });
    });
</script>
{% endblock %}