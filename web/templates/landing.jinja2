{% extends "base.jinja2" %}

{% block title %}Trang chủ - AI Brand Evaluator{% endblock %}

{% block content %}
<div class="relative flex-1 flex flex-col justify-center items-center pt-20 pb-32 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-neon/20 rounded-full blur-[120px] pointer-events-none"></div>
    
    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
        <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight mb-8">
            Phân tích thương hiệu đa chiều với <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-400">Multi-Agent AI</span>
        </h1>
        <p class="text-lg text-gray-400 mb-10 max-w-2xl mx-auto">
            Hệ thống tự động thu thập dữ liệu, phân tích cảm xúc và đánh giá uy tín thương hiệu của bạn trên không gian mạng theo thời gian thực.
        </p>
        
        <div class="flex items-center justify-center mt-8">
            <a href="/auth/login" class="inline-flex items-center gap-3 bg-brand-neon hover:bg-purple-500 text-white px-10 py-4 rounded-full text-lg font-semibold transition shadow-[0_0_20px_rgba(139,92,246,0.6)]">
                Bắt đầu trải nghiệm ngay
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
        </div>
    </div>
</div>
{% endblock %}